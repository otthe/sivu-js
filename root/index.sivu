<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sivu Home</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <?sivu
    const { backendFunction, printObject } = require('./backend.js');
    const path = require('path');
    let title = "This is a title"
    const currentPath = path.join(__dirname);
    const currentDate = new Date(8.64e15).toString();
    const test = console.log("hello world!");
    printObject($_SERVER);
  ?>
  <?include "_header.sivu"?>
  <h1><?= title ?></h1>
  <p><?= currentPath ?></p>
  <p><?= currentDate ?></p>
  <p><?= test ?></p>
  <p><?= backendFunction(); ?></p>

  <p> <?= var_dump($_SESSION ); ?> </p>
  <p> <?= var_dump($_SERVER ); ?> </p>
  <p> <?= var_dump($_GET ); ?> </p>

  <form method="POST" action="/add_user.sivu">
    <?= csrfField($_SESSION) ?>
    <label for="fname">First name:</label><br>
    <input type="text" id="fname" name="fname"><br>
    <label for="lname">Last name:</label><br>
    <input type="text" id="lname" name="lname">
    <button type="submit">Send</button>
  </form>

</body>
</html>