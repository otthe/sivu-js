<?sivu
const errs = {};
if (!$_POST.fname || $_POST.fname.trim().length < 2) errs.fname = "Too short";
if (Object.keys(errs).length) {
  flash("__errors", errs);
  flash("__old", { fname: $_POST.fname, lname: $_POST.lname });
  redirect("/index.sivu");
}

const first = $_POST.fname;
const last = $_POST.lname;

//db.createUser($_POST.fname, $_POST.lname);
flash("notice", $_POST.fname + " " + $_POST.lname);
redirect(`/index.sivu?fname=${first}&lname=${last}`);
?>